{
  "type": "panel",
  "title": "Kostal PIKO Adapter – Konfiguration",
  "items": {
    "_h1": {
      "type": "header",
      "text": "Wechselrichter-Verbindung",
      "size": 4
    },
    "pikoModel": {
      "type": "select",
      "label": "PIKO Modell",
      "help": "Modell des Wechselrichters – bestimmt die Anzahl der PV-Strings",
      "options": [
        {
          "value": "auto",
          "label": "Auto-Erkennung (aus HTML)"
        },
        {
          "value": "piko3.0",
          "label": "PIKO 3.0 (1 String)"
        },
        {
          "value": "piko3.6",
          "label": "PIKO 3.6 (2 Strings)"
        },
        {
          "value": "piko4.2",
          "label": "PIKO 4.2 (2 Strings)"
        },
        {
          "value": "piko5.5",
          "label": "PIKO 5.5 (3 Strings)"
        },
        {
          "value": "piko7.0",
          "label": "PIKO 7.0 (2 Strings)"
        },
        {
          "value": "piko8.3",
          "label": "PIKO 8.3 (2 Strings)"
        },
        {
          "value": "piko10.1",
          "label": "PIKO 10.1 (3 Strings)"
        }
      ],
      "default": "auto",
      "sm": 5
    },
    "_h_network": {
      "type": "header",
      "text": "Netzwerk-Zugang",
      "size": 4
    },
    "networkMode": {
      "type": "select",
      "label": "Netzwerk-Modus",
      "help": "Lokal: direkter Zugriff im gleichen Netzwerk. Via fritzwireguard: Zugriff über WireGuard-Tunnel der FritzBox (gleiche IP, anderes Netz).",
      "options": [
        {
          "value": "local",
          "label": "Lokal (direkter Zugriff)"
        },
        {
          "value": "fritzwireguard",
          "label": "Via iobroker.fritzwireguard (WireGuard-Tunnel)"
        }
      ],
      "default": "local",
      "sm": 6
    },
    "fritzwgInstance": {
      "type": "text",
      "label": "fritzwireguard Instanz",
      "help": "Name der fritzwireguard Adapter-Instanz, z. B. fritzwireguard.0",
      "default": "fritzwireguard.0",
      "sm": 4,
      "hidden": "data.networkMode !== 'fritzwireguard'"
    },
    "fritzwgConnectedState": {
      "type": "text",
      "label": "State-ID: Verbindungsstatus",
      "help": "Optionaler ioBroker State der anzeigt ob der WireGuard-Tunnel aktiv ist (boolean). Leer lassen = fritzwireguard.X.info.connection wird automatisch genutzt.",
      "placeholder": "z. B. fritzwireguard.0.info.connection",
      "default": "",
      "sm": 8,
      "hidden": "data.networkMode !== 'fritzwireguard'"
    },
    "ip": {
      "type": "text",
      "label": "IP-Adresse des Wechselrichters",
      "help": "z. B. 192.168.178.30",
      "default": "192.168.178.30",
      "sm": 6
    },
    "port": {
      "type": "number",
      "label": "HTTP-Port",
      "help": "Standard: 80",
      "default": 80,
      "min": 1,
      "max": 65535,
      "sm": 3
    },
    "_btnTest": {
      "type": "sendto",
      "label": "Verbindung testen",
      "command": "test",
      "jsonData": "{\"ip\": \"${data.ip}\", \"port\": ${data.port}, \"user\": \"${data.user}\", \"password\": \"${data.password}\"}",
      "sm": 12,
      "variant": "outlined"
    },
    "_h2": {
      "type": "header",
      "text": "Authentifizierung",
      "size": 4
    },
    "user": {
      "type": "text",
      "label": "Benutzername",
      "help": "Standard: pvserver",
      "default": "pvserver",
      "sm": 4
    },
    "password": {
      "type": "text",
      "inputType": "password",
      "label": "Passwort",
      "help": "HTTP Basic Auth Passwort des PIKO-Webservers (Standard: pvwr)",
      "default": "pvwr",
      "sm": 4
    },
    "_h3": {
      "type": "header",
      "text": "Live-Polling",
      "size": 4
    },
    "pollInterval": {
      "type": "number",
      "label": "Poll-Intervall (Sekunden)",
      "help": "Wie oft werden die Live-Messwerte vom Wechselrichter abgerufen. Empfohlen: 30 Sekunden",
      "default": 30,
      "min": 1,
      "max": 3600,
      "sm": 4
    },
    "_h4": {
      "type": "header",
      "text": "Historiendaten & InfluxDB-Synchronisation",
      "size": 4
    },
    "_info4": {
      "type": "staticText",
      "text": "Die LogDaten.dat enthält 15-Minuten-Messreihen der letzten ~6 Monate. Der Adapter lädt diese Datei automatisch in dem unten angegebenen Intervall, berechnet die echten Messzeitpunkte und überträgt neue Datenpunkte an InfluxDB. Die InfluxDB-Verbindung (Host, Port, Datenbank, Token) wird im ioBroker-Admin unter 'Adapter → InfluxDB' konfiguriert – nicht hier.",
      "sm": 12
    },
    "historyFetch": {
      "type": "checkbox",
      "label": "Historiendaten laden (LogDaten.dat)",
      "help": "Lädt die Messdaten der letzten ~6 Monate vom PIKO und zeigt sie im Web-UI an. Kein InfluxDB nötig.",
      "default": false,
      "sm": 12
    },
    "influxSync": {
      "type": "checkbox",
      "label": "Auch an InfluxDB senden",
      "help": "Sendet die Historiendaten zusätzlich an InfluxDB für Langzeitauswertungen. Nur sinnvoll wenn InfluxDB-Adapter installiert ist.",
      "default": false,
      "sm": 12,
      "hidden": "!data.historyFetch"
    },
    "syncInterval": {
      "type": "number",
      "label": "Sync-Intervall (Minuten)",
      "help": "Wie oft wird LogDaten.dat abgerufen und neue Datenpunkte an InfluxDB übertragen? Empfohlen: 15 (entspricht dem Messintervall des PIKO)",
      "default": 15,
      "min": 1,
      "max": 1440,
      "sm": 4
    },
    "influxInstance": {
      "type": "text",
      "label": "InfluxDB Adapter-Instanz",
      "help": "Name der installierten InfluxDB-Instanz in ioBroker. Verbindungsdaten (Host, Port, DB, Token) werden dort konfiguriert.",
      "default": "influxdb.0",
      "sm": 4
    },
    "_h5": {
      "type": "header",
      "text": "Web-Interface",
      "size": 4
    },
    "webPort": {
      "type": "number",
      "label": "Web-UI Port",
      "help": "Port für das eingebaute Dashboard (Tabs: Daten, Historie, Nodes, Logs, System). Standard: 8092",
      "default": 8092,
      "min": 1,
      "max": 65535,
      "sm": 4
    },
    "_h6": {
      "type": "header",
      "text": "Logging",
      "size": 4
    },
    "_h_modules": {
      "type": "header",
      "text": "PV-Modul Konfiguration (optional, für String-Analyse)",
      "size": 4
    },
    "_info_modules": {
      "type": "staticText",
      "text": "Optionale Angaben für die String-Analyse. Spannungs-Korridor basiert auf Vmpp (Betrieb), nicht Voc (Leerlauf). Vorlage wählen oder Werte manuell eintragen.",
      "sm": 12
    },
    "modulePreset": {
      "type": "select",
      "label": "Modul-Vorlage",
      "help": "Füllt Wp/Voc/Vmpp automatisch – Solarworld 225 Wp (~2010)",
      "options": [
        { "label": "Manuell / unbekannt", "value": "" },
        { "label": "Solarworld SW 225 poly (~2010)", "value": "sw225poly" },
        { "label": "Solarworld SW 225 mono", "value": "sw225mono" }
      ],
      "default": "",
      "sm": 4
    },
    "moduleWp": {
      "type": "number",
      "label": "Modul-Leistung (Wp)",
      "help": "Nennleistung eines Moduls, z. B. 225",
      "default": 0,
      "min": 0,
      "max": 1000,
      "sm": 3
    },
    "moduleVoc": {
      "type": "number",
      "label": "Leerlaufspannung Voc (V)",
      "help": "Leerlaufspannung bei STC (ohne Last), z. B. 36.8",
      "default": 0,
      "min": 0,
      "max": 100,
      "sm": 3
    },
    "moduleVmpp": {
      "type": "number",
      "label": "MPP-Spannung Vmpp (V)",
      "help": "Spannung am MPP bei STC, z. B. 29.5 – leer = auto aus Voc",
      "default": 0,
      "min": 0,
      "max": 100,
      "sm": 3
    },
    "string1Modules": {
      "type": "number",
      "label": "String 1: Anzahl Module",
      "help": "Anzahl Module in String 1",
      "default": 0,
      "min": 0,
      "max": 50,
      "sm": 3
    },
    "string2Modules": {
      "type": "number",
      "label": "String 2: Anzahl Module",
      "help": "Anzahl Module in String 2",
      "default": 0,
      "min": 0,
      "max": 50,
      "sm": 3
    },
    "string3Modules": {
      "type": "number",
      "label": "String 3: Anzahl Module (nur PIKO 5.5)",
      "help": "Anzahl Module in String 3 (nur bei PIKO 5.5)",
      "default": 0,
      "min": 0,
      "max": 50,
      "sm": 3
    },
    "verbose": {
      "type": "checkbox",
      "label": "Ausführliches Logging (Debug)",
      "default": false,
      "sm": 6
    },
    "_h_notify": {
      "type": "header",
      "text": "Benachrichtigungen",
      "size": 4
    },
    "_info_notify": {
      "type": "staticText",
      "text": "Berichte basieren auf LogDaten.dat – „Historiendaten laden“ muss aktiviert sein. SMTP-Zugangsdaten (Server, Benutzer, Passwort) werden im ioBroker E-Mail-Adapter konfiguriert, nicht hier. Telegram/Pushover-Token ebenfalls im jeweiligen Adapter.",
      "sm": 12,
      "hidden": "!data.notifyEnabled"
    },
    "notifyEnabled": {
      "type": "checkbox",
      "label": "Benachrichtigungen aktivieren",
      "default": false,
      "sm": 12
    },
    "notifyAdapter": {
      "type": "select",
      "label": "Benachrichtigungs-Adapter",
      "options": [
        {
          "value": "email",
          "label": "E-Mail"
        },
        {
          "value": "telegram",
          "label": "Telegram"
        },
        {
          "value": "pushover",
          "label": "Pushover"
        }
      ],
      "default": "email",
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyInstanceEmail": {
      "type": "text",
      "label": "E-Mail-Instanz",
      "help": "Name der ioBroker E-Mail-Adapter-Instanz, z. B. email.0",
      "default": "email.0",
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyInstanceTelegram": {
      "type": "text",
      "label": "Telegram-Instanz",
      "help": "Name der ioBroker Telegram-Adapter-Instanz, z. B. telegram.0",
      "default": "telegram.0",
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyInstancePushover": {
      "type": "text",
      "label": "Pushover-Instanz",
      "help": "Name der ioBroker Pushover-Adapter-Instanz, z. B. pushover.0",
      "default": "pushover.0",
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyRecipient": {
      "type": "text",
      "label": "Empfänger (E-Mail: Adresse, Telegram: Chat-ID)",
      "placeholder": "z. B. user@example.com oder 123456789",
      "default": "",
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "_h_notify_daily": {
      "type": "header",
      "text": "Tagesbericht",
      "size": 6,
      "hidden": "!data.notifyEnabled"
    },
    "notifyDaily": {
      "type": "checkbox",
      "label": "Tagesbericht aktivieren",
      "help": "Täglich ein Bericht mit Leistungskurve des Vortags",
      "default": false,
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyDailyTime": {
      "type": "text",
      "label": "Uhrzeit (HH:MM)",
      "default": "07:00",
      "sm": 3,
      "hidden": "!data.notifyEnabled || !data.notifyDaily"
    },
    "_h_notify_weekly": {
      "type": "header",
      "text": "Wochenbericht",
      "size": 6,
      "hidden": "!data.notifyEnabled"
    },
    "notifyWeekly": {
      "type": "checkbox",
      "label": "Wochenbericht aktivieren",
      "help": "Jeden Montag: Tagesleistungen der Vorwoche",
      "default": false,
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyWeeklyTime": {
      "type": "text",
      "label": "Uhrzeit (HH:MM)",
      "default": "07:00",
      "sm": 3,
      "hidden": "!data.notifyEnabled || !data.notifyWeekly"
    },
    "_h_notify_monthly": {
      "type": "header",
      "text": "Monatsbericht",
      "size": 6,
      "hidden": "!data.notifyEnabled"
    },
    "notifyMonthly": {
      "type": "checkbox",
      "label": "Monatsbericht aktivieren",
      "help": "Am 1. des Monats: alle Tagesleistungen des Vormonats",
      "default": false,
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyMonthlyTime": {
      "type": "text",
      "label": "Uhrzeit (HH:MM)",
      "default": "07:00",
      "sm": 3,
      "hidden": "!data.notifyEnabled || !data.notifyMonthly"
    },
    "_h_notify_alert": {
      "type": "header",
      "text": "Alarm",
      "size": 6,
      "hidden": "!data.notifyEnabled"
    },
    "notifyAlert": {
      "type": "checkbox",
      "label": "Alarm aktivieren",
      "help": "Benachrichtigung wenn Vortag keine Daten oder unter Schwellwert",
      "default": false,
      "sm": 4,
      "hidden": "!data.notifyEnabled"
    },
    "notifyAlertTime": {
      "type": "text",
      "label": "Uhrzeit (HH:MM)",
      "default": "07:00",
      "sm": 3,
      "hidden": "!data.notifyEnabled || !data.notifyAlert"
    },
    "notifyThresholdKwh": {
      "type": "number",
      "label": "Schwellwert (kWh, 0=deaktiviert)",
      "help": "Alarm wenn Tagesertrag unter diesem Wert liegt",
      "default": 0,
      "min": 0,
      "sm": 4,
      "hidden": "!data.notifyEnabled || !data.notifyAlert"
    }
  }
}